{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "crons": [
    {
      "path": "/api/internal/cron/test",
      "schedule": "30 18 * * *"
    },
    {
      "path": "/api/internal/cron/archive-activity-logs",
      "schedule": "0 0 * * *"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
