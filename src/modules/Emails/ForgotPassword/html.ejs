<!DOCTYPE html>
<html>
<head>
    <title>Forgot Password</title>
</head>
<body>
    <p>Hello <%= name %>,</p>
    
    <p>You have requested a password reset for your account with the email address <%= email %>.</p>
    
    <p><%= message %></p>
    
    <p>If you did not request this password reset, please ignore this email.</p>
    
    <p>Thank you,</p>
    <p>Your App Team</p>
</body>
</html>