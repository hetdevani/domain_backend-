{
    "compilerOptions": {
        "target": "es6",
        "module": "commonjs",
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "types": ["node"],
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.ts",
        "*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
